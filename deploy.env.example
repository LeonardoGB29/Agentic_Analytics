# Copia este archivo a deploy.env y rellena tus valores.
# deploy.env esta en .gitignore: NO se sube al repo.
#
#   cp deploy.env.example deploy.env
#   nano deploy.env

# Ruta a tu llave .pem de EMR (la misma con la que haces SSH al master)
SSH_KEY="~/Downloads/key_cluster.pem"

# DNS publico o IP PUBLICA del nodo MASTER.
# OJO: NO es la privada 172.31.x.x que ves en el prompt del master.
# La encuentras en la consola EMR -> tu cluster -> "Master public DNS".
MASTER_HOST="ec2-54-209-236-68.compute-1.amazonaws.com"

# Usuario SSH del cluster. En EMR es 'hadoop'.
REMOTE_USER="hadoop"

# Carpeta destino en el master donde se sube el codigo.
# OJO: en EMR la raiz (/home) es chica y suele estar llena. Usa /mnt (mas espacio).
REMOTE_DIR="/home/hadoop/agente_retail"

# Puerto donde corre el servidor Flask.
APP_PORT="5000"